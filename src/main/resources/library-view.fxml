<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LibraryController">
    <children>
        <Label alignment="CENTER" text="QUẢN LÝ THƯ VIỆN" textAlignment="CENTER" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="15.0">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <ComboBox fx:id="menu" layoutX="35.0" layoutY="55.0" prefWidth="200.0" AnchorPane.leftAnchor="35.0" AnchorPane.topAnchor="55.0" />

        <StackPane fx:id="mainStackPane" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="35.0" AnchorPane.rightAnchor="35.0" AnchorPane.topAnchor="100.0">
            <children>

                <AnchorPane fx:id="paneDocGia" style="-fx-background-color: white;">
                    <children>
                        <TextField fx:id="txtTimKiemDocGia" promptText="🔍 Tìm kiếm độc giả (Mã hoặc Tên)..." AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="310.0" AnchorPane.topAnchor="0.0" />

                        <TableView fx:id="readerTable" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="310.0" AnchorPane.topAnchor="35.0">
                            <columns>
                                <TableColumn fx:id="readerIDCol" prefWidth="55.0" text="ID" />
                                <TableColumn fx:id="readerNameCol" prefWidth="140.0" text="Tên độc giả" />
                                <TableColumn fx:id="actionReaderCol" prefWidth="100.0" text="Thao tác" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <TextArea fx:id="readerDetails" editable="false" prefWidth="280.0" promptText="Chi tiết mượn trả..." wrapText="true" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="180.0" />

                        <TextField fx:id="txtNhapIdSach" prefWidth="280.0" promptText="Nhập ID Sách để mượn/trả..." AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="140.0" />
                        <Button fx:id="btnMuonSach" prefWidth="135.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Mượn Sách" AnchorPane.rightAnchor="145.0" AnchorPane.bottomAnchor="100.0" />
                        <Button fx:id="btnTraSach" prefWidth="135.0" style="-fx-background-color: #FF9800; -fx-text-fill: white;" text="Trả Sách" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="100.0" />
                        <Button fx:id="btnInDocGia" prefWidth="280.0" style="-fx-background-color: #607D8B; -fx-text-fill: white;" text="🖨️ Xuất chi tiết độc giả (.txt)" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="60.0" />

                        <Separator prefWidth="300.0" AnchorPane.bottomAnchor="45.0" AnchorPane.leftAnchor="0.0" />
                        <TextField fx:id="txtThemIdDocGia" prefWidth="60.0" promptText="ID" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="0.0" />
                        <TextField fx:id="txtThemTenDocGia" prefWidth="160.0" promptText="Tên độc giả mới" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="70.0" />
                        <Button fx:id="btnThemDocGia" prefWidth="80.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Thêm ĐG" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="240.0" />
                    </children>
                </AnchorPane>

                <AnchorPane fx:id="paneSach" style="-fx-background-color: white;" visible="false">
                    <children>
                        <TextField fx:id="txtTimKiemSach" promptText="🔍 Tìm kiếm sách (Mã hoặc Tên sách)..." AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                        <TableView fx:id="bookTable" AnchorPane.bottomAnchor="110.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="35.0">
                            <columns>
                                <TableColumn fx:id="bookID" prefWidth="80.0" text="ID" />
                                <TableColumn fx:id="bookName" prefWidth="320.0" text="Tên sách" />
                                <TableColumn fx:id="remaining" prefWidth="80.0" text="SL" />
                                <TableColumn fx:id="actionBookCol" prefWidth="110.0" text="Thao tác" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <TextField fx:id="txtThemIdSach" prefWidth="80.0" promptText="Mã Sách" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="0.0" />
                        <TextField fx:id="txtThemTenSach" prefWidth="280.0" promptText="Tên sách mới" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="90.0" />
                        <TextField fx:id="txtThemSoLuong" prefWidth="60.0" promptText="SL" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="380.0" />
                        <Button fx:id="btnThemSach" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="➕ Nhập Kho" AnchorPane.bottomAnchor="65.0" AnchorPane.rightAnchor="0.0" />

                        <Button fx:id="btnNhapFile" prefWidth="130.0" style="-fx-background-color: #9C27B0; -fx-text-fill: white;" text="📂 Nhập từ file" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" />
                        <Button fx:id="btnInSach" prefWidth="130.0" style="-fx-background-color: #607D8B; -fx-text-fill: white;" text="🖨️ In DS Sách (.txt)" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="0.0" />

                        <Label text="* Lưu ý: ID trùng sẽ tự động cộng dồn số lượng" textFill="#797979" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="150.0">
                            <font><Font name="System Italic" size="12.0" /></font>
                        </Label>
                    </children>
                </AnchorPane>

            </children>
        </StackPane>
    </children>
</AnchorPane>